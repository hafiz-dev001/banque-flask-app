# Configuration de BANQUE NATIONALE

# Serveur Flask
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=app.py
SECRET_KEY=your_secret_key_change_this_in_production

# Base de données
DATABASE_NAME=bank.db
DATABASE_PATH=./bank.db

# Sécurité
SESSION_TIMEOUT=3600  # 1 heure en secondes
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_TIMEOUT=300  # 5 minutes

# Limites de transactions
MIN_TRANSFER_AMOUNT=0.01
MAX_TRANSFER_AMOUNT=999999.99
MIN_DEPOSIT_AMOUNT=1
MAX_DEPOSIT_AMOUNT=100000

# Frais
TRANSFER_FEE_PERCENTAGE=0.005  # 0.5%
DEPOSIT_FEE_PERCENTAGE=0.0     # Gratuit

# Solde initial
INITIAL_ACCOUNT_BALANCE=1000

# Configuration du serveur
HOST=localhost
PORT=5000
DEBUG=True
